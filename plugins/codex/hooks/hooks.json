{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "frontload hook pre-tool-use --host codex",
            "timeout": 10,
            "statusMessage": "Applying Frontload budget policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "frontload hook post-tool-use --host codex",
            "timeout": 10,
            "statusMessage": "Bounding Frontload command output"
          }
        ]
      }
    ]
  }
}
